R.Heartbeat:Connect(function(dt)
    EggDefenseTimer = EggDefenseTimer + dt
    local root, hum = LocalHRP(), getHum()
    if not root or not hum then return end
    
    if EggDefenseTimer >= 0.1 then
        if EggConfig.Defense.AntiGrab then 
            pcall(function() 
                STR:FireServer(L) 
            end) 
        end
        
        if EggConfig.Defense.AntiVoid and root.Position.Y < -87.5 then 
            root.CFrame = CFrame.new(0, 10, 0) 
        end
        
        if EggConfig.Defense.AntiRagdoll and hum:GetState() == Enum.HumanoidStateType.Ragdoll then 
            hum:ChangeState(Enum.HumanoidStateType.Running) 
        end
        
        EggDefenseTimer = 0
    end
    
    updateCameraZoom()
    
    if lastSuperZoomState ~= EggConfig.Camera.SuperZoom then
        updateCameraMode()
        lastSuperZoomState = EggConfig.Camera.SuperZoom
    end
end)

-- ============================================
-- オーラループ
-- ============================================
R.Heartbeat:Connect(function(dt)
    AuraTimer = AuraTimer + dt
    local root = LocalHRP()
    if not root then return end
    
    if Config.Target.TeleportToTarget and Config.Target.SelectedPlayer then
        local targetChar = Config.Target.SelectedPlayer.Character
        if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
            root.CFrame = targetChar.HumanoidRootPart.CFrame + Vector3.new(0, 5, 0)
        end
    end
    
    if AuraTimer >= 0.5 then
        local anyAuraActive = false
        for _, v in pairs(Config.Aura) do
            if type(v) == "boolean" and v then
                anyAuraActive = true
                break
            end
        end
        
        if anyAuraActive then
            local nearParts = GetNearPartsInSphere(root.Position, Config.Aura.Radius, Config.Aura.Height)
            
            for _, part in ipairs(nearParts) do
                if part.Name == "HumanoidRootPart" and not part:IsDescendantOf(L.Character) then
                    local character = part.Parent
                    SetNetworkOwner(part)
                    
                    affectedPlayers[character] = true
                    
                    if Config.Aura.SlowLegsAura then MakeSlowLegs(character) end
                    if Config.Aura.IrritateAura then IrritatePlayer(character) end
                    
                    if Config.Aura.BlastAura then 
                        local direction = (part.Position - root.Position).Unit
                        Velocity(part, direction * Config.Aura.BlastPower)
                    end
                    if Config.Aura.SpinAura then 
                        local bav = Instance.new("BodyAngularVelocity")
                        bav.MaxTorque = Vector3.new(1e8, 1e8, 1e8)
                        bav.AngularVelocity = Vector3.new(0, Config.Aura.SpinSpeed, 0)
                        bav.Parent = part
                        D:AddItem(bav, 0.1)
                    end
                    if Config.Aura.FlingAura then 
                        flingMemory[character] = true
                        local randomDir = Vector3.new(
                            math.random(-100, 100),
                            math.random(50, 100),
                            math.random(-100, 100)
                        ).Unit
                        Velocity(part, randomDir * Config.Aura.FlingPower)
                    end
                    if Config.Aura.KillAura then 
                        MoveTo(part, CFrame.new(4096, -75, 4096)) 
                        Velocity(part, Vector3.new(0, -1000, 0)) 
                    end
                    if Config.Aura.VoidAura then Velocity(part, Vector3.new(0, 10000, 0)) end
                end
            end
        end
        AuraTimer = 0
    end
    
    for character, _ in pairs(affectedPlayers) do
        if character and character.Parent then
            if Config.Aura.SlowLegsAura then
                MakeSlowLegs(character)
            end
            
            if Config.Aura.IrritateAura then
                IrritatePlayer(character)
            end
            
            if flingMemory[character] and Config.Aura.FlingAura then
                local root = character:FindFirstChild("HumanoidRootPart")
                if root then
                    local randomDir = Vector3.new(
                        math.random(-100, 100),
                        math.random(50, 100),
                        math.random(-100, 100)
                    ).Unit
                    Velocity(root, randomDir * Config.Aura.FlingPower / 2)
                end
            end
        else
            affectedPlayers[character] = nil
            flingMemory[character] = nil
        end
    end
    
    if Config.Target.KillAllLoop then
        task.spawn(function()
            for _, player in ipairs(P:GetPlayers()) do
                if player ~= L and player.Character then
                    KillPlayer(player)
                    task.wait(0.5)
                end
            end
        end)
    end
end)

