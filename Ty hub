local function TriggerBot()
    if not TriggerBotEnabled and not AutoShootEnabled then return end
    
    local mouse = L:GetMouse()
    local targetPart = mouse.Target
    
    if targetPart and targetPart.Parent then
        local humanoid = targetPart.Parent:FindFirstChild("Humanoid") or 
                         targetPart.Parent.Parent:FindFirstChild("Humanoid")
        
        if humanoid and humanoid.Health > 0 then
            local player = game.Players:GetPlayerFromCharacter(targetPart.Parent)
            if player and player ~= L then
                local screenPoint = Cam:WorldToScreenPoint(targetPart.Position)
                if screenPoint.Z > 0 then
                    if AutoShootEnabled then
                        mouse1click()
                    elseif TriggerBotEnabled then
                        mouse1click()
                        wait(TriggerBotDelay)
                    end
                end
            end
        end
    end
end

