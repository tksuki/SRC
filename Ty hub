local function resetUIColor()
    if rainbowConnection then 
        rainbowConnection:Disconnect()
        rainbowConnection = nil
    end
    
    local defaultColor = Color3.fromRGB(255, 255, 255)
    
    for Name, Type in pairs(OrionLib.ThemeObjects) do 
        if Name == "Stroke" or Name == "Divider" then 
            for _, Object in pairs(Type) do 
                if Object and Object.Parent then 
                    local property = Object:IsA("UIStroke") and "Color" or "BackgroundColor3"
                    Object[property] = defaultColor 
                end 
            end 
        end 
    end
    
    for _, Object in pairs(OrionLib.ThemeObjects.Text or {}) do 
        if Object and Object.Parent then 
            if Object:IsA("TextLabel") and Object.Name == "TabTitle" then 
                Object.TextColor3 = defaultColor
            end 
