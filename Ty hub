local saDist = 30
local SIL = false

local function STS()
    if not (U.MouseEnabled or U.TouchEnabled) then return end 
    local Hitbox = {"Head", "Torso", "Left Leg", "Right Leg"}
    
    local function GetClosest()
        local Target, Closest = nil, math.huge 
        for _, player in pairs(P:GetPlayers()) do 
            if player.Name ~= L.Name and player.Character and L and L.Character and L.Character.HumanoidRootPart then 
                local playerPosition = L.Character.HumanoidRootPart.Position 
                local humanoidRootPart = player.Character:FindFirstChild("HumanoidRootPart")
                if humanoidRootPart then 
                    local screenPos, onScreen = Cam:WorldToScreenPoint(humanoidRootPart.Position)
                    if onScreen then 
                        local distance = (playerPosition - humanoidRootPart.Position).magnitude 
                        if distance < Closest then Closest, Target = distance, player end 
                    end 
                end 
            end 
        end 
        return Target 
    end 
    
    local Target, part, partn, ch 
    R.RenderStepped:Connect(function() Target = GetClosest() end)
    
    local function CalculateDirection(Origin, Destination, Length) 
        return (Destination - Origin).Unit * Length 
    end 
    
    local __namecall 
    __namecall = hookmetamethod(game, "__namecall", function(...)
        local args = {...}
        local self, method = args[1], getnamecallmethod()
        if self == workspace and not checkcaller() and method == "Raycast" and Target and Target.Character and Target.Character.HumanoidRootPart and L.Character.HumanoidRootPart and Target.Character.Humanoid and Target.Character.Humanoid.Health > 0 and SIL then 
            local playerPosition, targetPosition = L.Character.HumanoidRootPart.Position, Target.Character.HumanoidRootPart.Position 
            local distance = (playerPosition - targetPosition).magnitude 
            part = math.random(1, #Hitbox)
            partn = Hitbox[part]
            ch = Target.Character[partn]
            if distance <= saDist and ch then 
                args[3] = CalculateDirection(args[2], Target.Character[partn].Position, 1000)
                args[4] = RaycastParams.new()
                args[4].FilterDescendantsInstances, args[4].FilterType = {Target.Character}, Enum.RaycastFilterType.Include 
                part, partn, ch = nil, nil, nil 
            end 
        end 
        return __namecall(unpack(args))
    end)
end

