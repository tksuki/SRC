    end
    
    rainbowConnection = R.RenderStepped:Connect(function()
        local hue = tick() % 5 / 5 
        local color = Color3.fromHSV(hue, 0.8, 1)
        
        for Name, Type in pairs(OrionLib.ThemeObjects) do 
