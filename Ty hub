local WingsEnabled = false
local WingsSpacing = 0.0
local WingsHeight = 2.0  
local WingsBackOffset = 0.5  
local WingsSideOffset = 0.0
local WingsWaveAmp = 2.5
local WingsWaveSpeed = 5.0
local WingsTwistAngle = 20.0
local WingsTwistSpeed = 5.0
local WingsTwistWave = 0.5
local WingsTargetSet = "Sparkler"
local WingsDefaultZoom = 12

local WingsTargetSets = {
    ["GlassBox"] = {"GlassBoxGray"},
    ["Pallet"] = {"PalletLightBrown"},
    ["Sparkler"] = {"FireworkSparkler"},
    ["Toilet"] = {"ToiletWhite","ToiletGold"},
    ["Piano"] = {"KeyboardPart", "MusicKeyboard"},
    ["Stick"] = {"Stick"}
}

local WingsList, WingsLoopConn = {}, nil
local WingsTimer = 0
WingsTargetPlayer = nil

-- WINGS用HRP
local function WingsHRP()
    if WingsTargetPlayer and WingsTargetPlayer.Character and WingsTargetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return WingsTargetPlayer.Character.HumanoidRootPart
    end
    local c = L.Character or L.CharacterAdded:Wait()
    return c:FindFirstChild("HumanoidRootPart")
end

local function WingsGetPartFromModel(m)
    if m.PrimaryPart then return m.PrimaryPart end
    return m:FindFirstChildWhichIsA("BasePart")
end

local function WingsNameInTargets(n)
    local t = WingsTargetSets[WingsTargetSet]
    if not t then return false end
    for _, nm in ipairs(t) do if n == nm then return true end end
    return false
end

local function WingsAttachPhysics(rec)
    local model = rec.model; local part = rec.part
    if not model or not part or not part.Parent then return end
    for _, p in ipairs(model:GetDescendants()) do
        if p:IsA("BasePart") and not p:IsA("BodyMover") then
            pcall(function() p:SetNetworkOwner(L) end)
            p.CanCollide, p.CanTouch = false, false
        end
    end
    if not part:FindFirstChild("BodyVelocity") then
        local bv = Instance.new("BodyVelocity", part); bv.Name = "BodyVelocity"; bv.MaxForce = Vector3.new(1e8,1e8,1e8); bv.Velocity = Vector3.new(); bv.P = 1e6
    end
    if not part:FindFirstChild("BodyGyro") then
        local bg = Instance.new("BodyGyro", part); bg.Name = "BodyGyro"; bg.MaxTorque = Vector3.new(1e8,1e8,1e8); bg.CFrame = part.CFrame; bg.P = 1e6
    end
end

local function WingsDetachPhysics(rec)
    local model = rec.model; local part = rec.part
    if not model or not part then return end
    if part:FindFirstChild("BodyVelocity") then part.BodyVelocity:Destroy() end
    if part:FindFirstChild("BodyGyro") then part.BodyGyro:Destroy() end
    for _, p in ipairs(model:GetDescendants()) do
        if p:IsA("BasePart") and not p:IsA("BodyMover") then
            p.CanCollide, p.CanTouch = true, true
            pcall(function() p:SetNetworkOwner(nil) end)
        end
    end
end

local function WingsRescan()
    for _,r in ipairs(WingsList) do WingsDetachPhysics(r) end
    WingsList = {}
    for _, d in ipairs(W:GetDescendants()) do
        if d:IsA("Model") and WingsNameInTargets(d.Name) then
            local part = WingsGetPartFromModel(d)
            if part and not part.Anchored then table.insert(WingsList, {model=d, part=part}) end
        elseif d:IsA("BasePart") and WingsNameInTargets(d.Name) then 
            if not d.Anchored then table.insert(WingsList, {model=d, part=d}) end
        end
    end
    for i = 1, #WingsList do WingsAttachPhysics(WingsList[i]) end
end

local function WingsStartLoop()
    if WingsLoopConn then WingsLoopConn:Disconnect() end
    WingsTimer = 0
    WingsLoopConn = R.Heartbeat:Connect(function(dt)
        local root = WingsHRP()
        if not root or #WingsList == 0 then return end
        WingsTimer = WingsTimer + dt
        local wingsCenter = root.CFrame * CFrame.new(WingsSideOffset, WingsHeight, WingsBackOffset)
        local WaveConstant = math.pi / #WingsList
        for j = 1, #WingsList do
            local rec = WingsList[j]; local p = rec.part
            if p and p.Parent then
                local isRight = (j % 2 == 0); local sign = isRight and 1 or -1
                local animationIndex = math.ceil(j / 2)
                local distanceIndex = isRight and (j - 2) / 2 or (j - 1) / 2
                local xOffset = WingsSpacing * (distanceIndex + 0.2) * sign
                local waveOffset = WingsWaveAmp * math.sin(WingsWaveSpeed * WingsTimer + animationIndex * WaveConstant)
                local twistOscillation = math.sin(WingsTwistSpeed * WingsTimer + animationIndex * WingsTwistWave)
                local currentTwistAngle = math.rad(WingsTwistAngle * twistOscillation * (distanceIndex / (#WingsList / 2)))
                local targetCFrame = wingsCenter * CFrame.Angles(currentTwistAngle, 0, 0) * CFrame.new(xOffset, waveOffset, 0)    
                if p:FindFirstChild("BodyVelocity") then p.BodyVelocity.Velocity = (targetCFrame.Position - p.Position) * 20 end    
                if p:FindFirstChild("BodyGyro") then p.BodyGyro.CFrame = targetCFrame end    
            end    
        end
    end)
end

-- 竜巻モード（WINGS）
local WingsTornadoEnabled = false
local WingsTornadoRadius = 13.5
local WingsTornadoHeight = 23
local WingsTornadoSpeed = 4
local WingsTornadoConn = nil

local function WingsStartTornado()
    if WingsTornadoConn then WingsTornadoConn:Disconnect() end
    WingsRescan()  
    WingsTornadoConn = R.Heartbeat:Connect(function(dt)  
        local root = WingsHRP()  
        if not root or #WingsList == 0 then return end  
        WingsTimer = WingsTimer + dt  
        local baseCF = root.CFrame  
        for i, rec in ipairs(WingsList) do  
            local p = rec.part  
            if p and p.Parent then  
                local heightOffset = (i / #WingsList) * WingsTornadoHeight  
                local angle = (WingsTimer * WingsTornadoSpeed) + (i * math.pi * 2 / #WingsList)  
                local x = math.cos(angle) * WingsTornadoRadius  
                local z = math.sin(angle) * WingsTornadoRadius  
                local targetCFrame = baseCF * CFrame.new(x, heightOffset, z) * CFrame.Angles(0, angle, 0)  
                if p:FindFirstChild("BodyVelocity") then p.BodyVelocity.Velocity = (targetCFrame.Position - p.Position) * 30 end  
                if p:FindFirstChild("BodyGyro") then p.BodyGyro.CFrame = targetCFrame end  
            end  
        end  
    end)
end

local function WingsStopTornado()
    if WingsTornadoConn then WingsTornadoConn:Disconnect(); WingsTornadoConn = nil end
    for _, rec in ipairs(WingsList) do WingsDetachPhysics(rec) end  
    WingsList = {}
end

