-- コーンモード（WINGS）
local WingsConeMaxH, WingsConeGrowS, WingsConeRadius, WingsConeSpeed, WingsConeConn = 40, 2, 15, 10, nil

local function WingsStartCone()
    if WingsConeConn then WingsConeConn:Disconnect() end
    WingsRescan()
    WingsConeConn = R.Heartbeat:Connect(function(dt)
        local root = WingsHRP()
        if not root or not WingsList or #WingsList == 0 then return end
        WingsTimer = WingsTimer + dt
        local curH = (math.sin(WingsTimer * WingsConeGrowS) + 1) / 2 * WingsConeMaxH
        for i, rec in ipairs(WingsList) do
            local p = rec.part
            if p and p.Parent then
                local prog = i / #WingsList
                local r = WingsConeRadius * (1 - prog)
                local h = prog * curH
                local ang = (WingsTimer * (WingsConeSpeed / 2)) + (i * math.pi * 2 / #WingsList)
                local targetCF = root.CFrame * CFrame.new(math.cos(ang)*r, h, math.sin(ang)*r) * CFrame.Angles(0, ang, 0)
                if p:FindFirstChild("BodyVelocity") then p.BodyVelocity.Velocity = (targetCF.Position - p.Position) * 30 end
                if p:FindFirstChild("BodyGyro") then p.BodyGyro.CFrame = targetCF end
            end
        end
    end)
