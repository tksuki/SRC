local function GetNearPartsInSphere(origin, radius, height)
    local sphere = Instance.new("Part")
    sphere.Size = Vector3.new(radius * 2, height * 2, radius * 2)
    sphere.Position = origin
    sphere.Anchored = true
    sphere.CanCollide = false
    sphere.Transparency = 1
    sphere.Parent = W
    
    local parts = W:GetPartsInPart(sphere)
    sphere:Destroy()
    
    local partsInSphere = {}
    for _, part in ipairs(parts) do
        local distance = (part.Position - origin).Magnitude
        local heightDiff = math.abs(part.Position.Y - origin.Y)
        
        if distance <= radius and heightDiff <= height / 2 then
            table.insert(partsInSphere, part)
        end
    end
    
    return partsInSphere
end

