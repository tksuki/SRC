local function GetPlayersInOrder()
    local allPlayers = {}
    for _, player in ipairs(P:GetPlayers()) do
        if player ~= L and player.Character then
            table.insert(allPlayers, player)
        end
    end
    return allPlayers
end

local function TeleportToPlayer(player)
    if not player or player == L then return end
    local targetChar = player.Character
    if not targetChar then return end
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end
    
    local myHRP = LocalHRP()
    if not myHRP then return end
    
    local camera = Cam
    local cameraCF = camera.CFrame
    local rightVector = cameraCF.RightVector
    local teleportPosition = targetHRP.Position + (rightVector * 5)
    
    myHRP.CFrame = CFrame.new(teleportPosition, targetHRP.Position)
end

local function StartAllTeleportLoop()
    if AllTeleportActive then return end
    AllTeleportActive = true
    AllTeleportIndex = 1
    
    local allPlayers = GetPlayersInOrder()
    
    if #allPlayers == 0 then
        AllTeleportActive = false
        return
    end
    
    task.spawn(function()
        while AllTeleportActive do
            local player = allPlayers[AllTeleportIndex]
            if player then
                TeleportToPlayer(player)
            end
            
            AllTeleportIndex = AllTeleportIndex + 1
            if AllTeleportIndex > #allPlayers then
                AllTeleportIndex = 1
            end
            
            task.wait(AllTeleportInterval)
        end
    end)
end

local function StopAllTeleportLoop()
    AllTeleportActive = false
end

local function KillPlayer(player)
    if not player or not player.Character then return end
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local myPos = LocalHRP()
    if not myPos then return end
    
    local myPosCF = myPos.CFrame
    myPos.CFrame = root.CFrame + Vector3.new(0, -6, 0)
    task.wait(0.1)
    
    for i = 1, 4 do 
        SetNetworkOwner(root, myPos.CFrame) 
        task.wait(0.05) 
    end
    
    MoveTo(root, CFrame.new(4096, -75, 4096))
    Velocity(root, Vector3.new(0, -1000, 0))
    
    task.wait(0.3)
    myPos.CFrame = myPosCF
end

