    for i, target in ipairs(players) do
        if target.Character and positions[i] then
            local root = target.Character:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = CFrame.new(positions[i].x, PLAYER_Y + yOffset, positions[i].z)
            end
        end
    end
end

-- ==================== Kick All メイン処理 ====================
local function ExecuteKickAll()
    local allPlayers = GetAllPlayers()
    if #allPlayers == 0 then
        Notify("エラー", "他のプレイヤーがいません", 2)
        return
    end

    kickAllActive = true

    if blackHoleCount > 0 then
        Notify("注意", "検知済みBlackHole: " .. blackHoleCount .. "個", 3)
    end

    -- 1. Blobmanスポーン & 自動乗車
    local blob = SpawnAndRideBlobman()
    if not blob then
        Notify("エラー", "Blobmanに乗れませんでした", 3)
        kickAllActive = false
        return
    end
    
    Notify("成功", "Blobmanに乗車しました", 1.5)
    task.wait(0.3)

    local myRoot = GetMyRoot()
    if not myRoot then
        kickAllActive = false
        return
    end

    -- 2. 各プレイヤーにGrabRelease
    for _, target in ipairs(allPlayers) do
        local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            TeleportToTarget(targetRoot)
            SetNetworkOwner(targetRoot)
            
            for j = 1, 3 do
                GrabRelease(blob, target)
                if j < 3 then task.wait(0.08) end
            end
        end
    end

    -- 3. 自分の位置を設定
    myRoot.CFrame = CFrame.new(0, SELF_Y, 0)
    task.wait(0.1)

    -- 4. Blobをアンカー
    AnchorBlob(blob)
    task.wait(0.1)

    -- 5. プレイヤーを配置
    local centerX, centerZ = 0, 0
    
    if placementMode == "circle" then
        TeleportPlayersToPositions(allPlayers, centerX, centerZ, 0, GetCirclePositions, circleRadius, #allPlayers)
    elseif placementMode == "double" then
        TeleportPlayersToPositions(allPlayers, centerX, centerZ, 0, GetDoubleCirclePositions, innerRadius, outerRadius, #allPlayers)
    elseif placementMode == "spiral" then
        TeleportPlayersToPositions(allPlayers, centerX, centerZ, 0, GetSpiralPositions, spiralStart, spiralEnd, #allPlayers)
    end
    
    task.wait(0.1)

    -- 6. Grab実行
    for _, target in ipairs(allPlayers) do
        local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then DoGrab(targetRoot) end
    end
    task.wait(0.1)
    
    for _, target in ipairs(allPlayers) do
        local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then DoGrab(targetRoot) end
    end
    task.wait(0.3)

    -- 7. Kick実行
    for i = 1, 3 do
        for _, target in ipairs(allPlayers) do
            KickBoth(blob, target)
        end
        if i < 3 then task.wait(0.08) end
    end

    task.wait(0.1)
    UnanchorBlob(blob)

    Notify("Kick All 完了", #allPlayers .. "人をキック | 半径: " .. circleRadius, 4)
    kickAllActive = false
end

